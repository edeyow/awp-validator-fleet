{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wikipedia Article",
  "type": "object",
  "properties": {
    "page_id": { "type": ["integer", "string"], "description": "MediaWiki page ID" },
    "title": { "type": "string", "description": "Article title" },
    "language": { "type": "string", "description": "ISO 639-1 language code" },
    "canonical_url": { "type": "string", "format": "uri" },
    "dedup_key": { "type": "string", "description": "Deduplication key (page_id:language)" },
    "categories": { "type": "array", "items": { "type": "string" } },
    "references_count": { "type": "integer" },
    "external_links_count": { "type": "integer" },
    "section_count": { "type": "integer" },
    "number_of_sections": { "type": "integer" },
    "images": { "type": "array", "items": { "type": "string" } },
    "image_count": { "type": "integer" },
    "article_creation_date": { "type": "string" },
    "protection_level": { "type": "string" },
    "word_count": { "type": "integer" },
    "see_also": { "type": "array", "items": { "type": "string" } },
    "domain": { "type": "string" },
    "topic_hierarchy": { "type": "array", "items": { "type": "string" } },
    "subject_tags": { "type": "array", "items": { "type": "string" } },
    "entity_type": { "type": "string" },
    "canonical_entity_name": { "type": "string" }
  },
  "required": ["page_id", "title", "language", "canonical_url"]
}
